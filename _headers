# Cloudflare Pages headers — https://developers.cloudflare.com/pages/configuration/headers/
# Applied edge-side. Order: most-specific paths can override broader ones.

# HTML must never be cached, so new deploys are picked up immediately.
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Assets are NOT content-hashed (fixed names like styles.css, app.js), so they
# must revalidate — an immutable long cache would hide updates from returning
# visitors. Cheap 304s keep it fast while always serving the latest after deploy.
/assets/*
  Cache-Control: public, max-age=0, must-revalidate

# Security headers + CSP for every route.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  X-XSS-Protection: 0
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; img-src 'self' data: blob: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://esm.sh https://cdn.jsdelivr.net; connect-src 'self' https://esm.sh https://cdn.jsdelivr.net https://*.supabase.co wss://*.supabase.co; frame-src 'self' https://www.youtube.com https://drive.google.com https://docs.google.com; manifest-src 'self'; upgrade-insecure-requests
